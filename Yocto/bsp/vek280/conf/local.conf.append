# Quad SFP28 FMC (XXV) overrides for vek280 (Versal), EDF flow.
# bsp/vek280 gets its own MACHINE/SDT from its own Vivado XSA via
# gen-machineconf parse-sdt (PS + PL device tree derived from hardware);
# MACHINE is NOT pinned. Versal EDF wks partitions esp(vfat)/storage/root(ext4); console comes
# from the SDT. Bump CMA if a target needs larger DMA buffers.
APPEND:append = " earlycon clk_ignore_unused rw rootwait cma=1536M"

# Hostname (overrides amd-edf default of "amd-edf").
hostname:pn-base-files = "vek280-sfp-2025-2"

# Reserve space in the rootfs for image-time installs.
IMAGE_ROOTFS_EXTRA_SPACE = "524288"
